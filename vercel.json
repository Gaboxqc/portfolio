{
  "rewrites": [
    {
      "source": "/statpitch",
      "destination": "https://statpitch-frontend.vercel.app/"
    },
    {
      "source": "/statpitch/:path*",
      "destination": "https://statpitch-frontend.vercel.app/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
